        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Zoho-oauthtoken {{ $json.zoho_access_token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ data: [$json.zoho_record], duplicate_check_fields: $json.upsert_criteria.duplicate_check_fields }) }}",
        "options": {
          "timeout": 15000,
          "response": { "response": { "neverError": true } }
        }
      },
      "id": "zoho-upsert",
      "name": "06c — Zoho CRM Upsert",
      "type": "n8n-nodes-base.httpRequest",
      "position": [2620, 300],
      "typeVersion": 4,
      "notesInFlow": true,
      "notes": "Upserts Lead with all custom fields. Zoho Workflow Rules trigger emails automatically.",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "functionCode": "// Paste contents of n8n/nodes/04-completion-branching.js\n// Marks partial records as completed, prepares state transition"
      },
      "id": "completion-branching",
      "name": "07 — Completion Branching",
      "type": "n8n-nodes-base.function",
      "position": [2840, 300],
      "typeVersion": 1,
      "notesInFlow": true,
      "notes": "State machine: marks prior partial as completed. Zoho handles nurture enrollment via Cadences."
    },
    {
      "parameters": {
        "functionCode": "// Paste contents of n8n/nodes/09-admin-godview.js\n// Admin notification — internal only, still sends via Postmark/SMTP"
      },
      "id": "admin-godview",
      "name": "08 — Admin God-View Email",
      "type": "n8n-nodes-base.function",
      "position": [3060, 200],
      "typeVersion": 1,
      "notesInFlow": true,
      "notes": "Internal admin notification. Still uses Postmark — this is NOT a lead-facing email."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.postmarkapp.com/email",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Postmark-Server-Token", "value": "={{ $env.POSTMARK_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ From: $json.From, To: $json.To, Subject: $json.Subject, HtmlBody: $json.HtmlBody, TextBody: $json.TextBody, Attachments: $json.Attachments || [], MessageStream: 'outbound' }) }}",
        "options": {
          "timeout": 15000,
          "response": { "response": { "neverError": true } }
        }
      },
      "id": "postmark-admin",
      "name": "Postmark: Admin Email",
      "type": "n8n-nodes-base.httpRequest",
      "position": [3280, 200],
      "typeVersion": 4,
      "notesInFlow": true,
      "notes": "Admin-only email via Postmark. Lead-facing emails handled by Zoho.",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.strategic_gap_score }}",
              "operation": "larger",
              "value2": 7
            }
          ]
        }
